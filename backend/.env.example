# Copy this file to .env and fill in real values.
# Never commit .env to version control.

# Django
SECRET_KEY=change-me-to-a-long-random-string
DJANGO_SETTINGS_MODULE=config.settings.local

# Database (choose one form)
# Option A — full URL:
DATABASE_URL=postgres://openvoor:password@localhost:5432/openvoor_socials
# Option B — individual vars (used when DATABASE_URL is empty):
# DB_NAME=openvoor_socials
# DB_USER=openvoor
# DB_PASSWORD=password
# DB_HOST=localhost
# DB_PORT=5432

# External APIs
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=your-google-api-key-here

# Meta / Facebook Graph API
FACEBOOK_PAGE_ID=123456789
FACEBOOK_PAGE_ACCESS_TOKEN=EAABsb...
FACEBOOK_APP_SECRET=your-app-secret-here
FACEBOOK_AD_ACCOUNT_ID=act_your-ad-account-id
INSTAGRAM_USER_ID=987654321

# Public base URL (used to build image URLs sent to social APIs)
BASE_URL=https://social.open4.app

# Production only
ALLOWED_HOSTS=social.open4.app
