# Copy to .env and fill in real values. Never commit .env.

# Django
SECRET_KEY=change-me-to-a-long-random-string
DJANGO_SETTINGS_MODULE=config.settings.production

# Shared PostgreSQL (msucoo_pg01 on Coolify)
DATABASE_URL=postgres://app_openvoorsocials:YOURPASSWORD@192.168.0.172:5433/app_openvoorsocials

# External APIs
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=AIza...

# Meta / Facebook Graph API
FACEBOOK_PAGE_ID=123456789
FACEBOOK_PAGE_ACCESS_TOKEN=EAABsb...
INSTAGRAM_USER_ID=987654321

# Public base URL (used to build image URLs sent to social APIs)
BASE_URL=https://social.open4.app
ALLOWED_HOSTS=social.open4.app
